# Copiá este archivo como .env para desarrollo local
# En producción (Render), configurá estas variables en el dashboard de Render

# URL de conexión a la base de datos (Neon u otro PostgreSQL)
DATABASE_URL=postgresql://usuario:contraseña@host/nombre_db?sslmode=require

# Contraseña del SuperAdmin (se usa solo si el SuperAdmin no existe aún)
SUPERADMIN_PASSWORD=tu_contraseña_segura_aqui
